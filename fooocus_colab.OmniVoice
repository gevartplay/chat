      },
      "source": [
        "<a href=\"https://colab.research.google.com/github/gevartplay/chat/blob/main/fooocus_colab.OmniVoice\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ================================================================\n",
        "#  OmniVoice — Google Colab (Исправленная версия, официальный API)\n",
        "#  Runtime -> Change runtime type -> T4 GPU\n",
        "# ================================================================\n",
        "\n",
        "import subprocess\n",
        "# Добавлена библиотека pydub для конвертации в mp3\n",
        "subprocess.run(\"pip install -q omnivoice gradio soundfile pydub\", shell=True, check=True)\n",
        "print(\"✅ Библиотеки установлены\")\n",
        "\n",
        "import torch\n",
        "import numpy as np\n",
        "import soundfile as sf\n",
        "import tempfile\n",
        "import gradio as gr\n",
        "from pydub import AudioSegment\n",
        "from omnivoice import OmniVoice, OmniVoiceGenerationConfig\n",
        "\n",
        "print(\"⏳ Загружаем модель k2-fsa/OmniVoice (~4GB)...\")\n",
        "model = OmniVoice.from_pretrained(\n",
        "    \"k2-fsa/OmniVoice\",\n",
        "    device_map=\"cuda:0\",\n",
        "    dtype=torch.float16,\n",
        "    load_asr=True,  # нужно, чтобы можно было НЕ указывать ref_text\n",
        ")\n",
        "sampling_rate = model.sampling_rate\n",
        "print(\"✅ Модель загружена!\\n\")\n",
        "\n",
        "\n",
        "def generate_tts(text, ref_audio, ref_text, speaker_prompt, mode,\n",
        "                 num_step, guidance_scale, speed, language):\n",
        "    if not text or not text.strip():\n",
        "        return None, \"⚠️ Введите текст!\"\n",
        "\n",
        "    try:\n",
        "        # 1. Конфиг генерации — ИМЕННО так, как в официальном demo.py\n",
        "        gen_config = OmniVoiceGenerationConfig(\n",
        "            num_step=int(num_step),\n",
        "            guidance_scale=float(guidance_scale),\n",
        "            denoise=True,\n",
        "            preprocess_prompt=True,\n",
        "            postprocess_output=True,\n",
        "        )\n",
        "\n",
        "        lang = language if (language and language != \"Auto\") else None\n",
        "\n",
        "        kw = dict(\n",
        "            text=text.strip(),\n",
        "            language=lang,\n",
        "            generation_config=gen_config,\n",
        "        )\n",
        "\n",
        "        if speed is not None and float(speed) != 1.0:\n",
        "            kw[\"speed\"] = float(speed)\n",
        "\n",
        "        # 2. Режимы — строго по официальному API\n",
        "        if mode == \"🎤 Клонирование голоса\":\n",
        "            if not ref_audio:\n",
        "                return None, \"⚠️ Загрузите референсное аудио для клонирования!\"\n",
        "            # ВАЖНО: ref_audio/ref_text НЕЛЬЗЯ передавать напрямую в generate().\n",
        "            # Нужно создать voice_clone_prompt через хелпер модели.\n",
        "            kw[\"voice_clone_prompt\"] = model.create_voice_clone_prompt(\n",
        "                ref_audio=ref_audio,\n",
        "                ref_text=ref_text.strip() if ref_text and ref_text.strip() else None,\n",
        "            )\n",
        "\n",
        "        elif mode == \"🎨 Voice Design\":\n",
        "            if speaker_prompt and speaker_prompt.strip():\n",
        "                kw[\"instruct\"] = speaker_prompt.strip()\n",
        "\n",
        "        # 3. Генерация\n",
        "        audio = model.generate(**kw)\n",
        "        # audio[0] — это np.ndarray формы (T,) на 24 кГц\n",
        "\n",
        "        # Сохраняем во временный wav\n",
        "        tmp_wav = tempfile.NamedTemporaryFile(suffix=\".wav\", delete=False)\n",
        "        sf.write(tmp_wav.name, audio[0], sampling_rate)\n",
        "\n",
        "        # Конвертируем в mp3\n",
        "        tmp_mp3 = tempfile.NamedTemporaryFile(suffix=\".mp3\", delete=False)\n",
        "        AudioSegment.from_wav(tmp_wav.name).export(tmp_mp3.name, format=\"mp3\")\n",
        "\n",
        "        return tmp_mp3.name, \"✅ Успешно сгенерировано\"\n",
        "\n",
        "    except Exception as e:\n",
        "        import traceback\n",
        "        traceback.print_exc()\n",
        "        return None, f\"❌ {type(e).__name__}: {e}\"\n",
        "\n",
        "\n",
        "def update_ui(mode):\n",
        "    clone  = mode == \"🎤 Клонирование голоса\"\n",
        "    design = mode == \"🎨 Voice Design\"\n",
        "    return (\n",
        "        gr.update(visible=clone),\n",
        "        gr.update(visible=clone),\n",
        "        gr.update(visible=design),\n",
        "    )\n",
        "\n",
        "\n",
        "with gr.Blocks(title=\"OmniVoice TTS (Russian UI)\", theme=gr.themes.Soft()) as demo:\n",
        "    gr.Markdown(\"\"\"\n",
        "    # 🔊 OmniVoice TTS\n",
        "    **600+ языков** · Voice Cloning · Voice Design\n",
        "    \"\"\")\n",
        "\n",
        "    with gr.Row():\n",
        "        with gr.Column(scale=3):\n",
        "            text_input = gr.Textbox(\n",
        "                label=\"Текст для озвучки\",\n",
        "                placeholder=\"Введите текст. Для очень длинных текстов рекомендуется \"\n",
        "                            \"разбивать на абзацы и генерировать по частям.\",\n",
        "                lines=7,\n",
        "            )\n",
        "            mode = gr.Radio(\n",
        "                choices=[\"🗣️ Обычный TTS\", \"🎤 Клонирование голоса\", \"🎨 Voice Design\"],\n",
        "                value=\"🗣️ Обычный TTS\",\n",
        "                label=\"Режим\",\n",
        "            )\n",
        "\n",
        "            with gr.Accordion(\"⚙️ Настройки генерации\", open=False):\n",
        "                with gr.Row():\n",
        "                    num_step = gr.Slider(4, 64, value=32, step=1,\n",
        "                                         label=\"Шаги диффузии (num_step)\")\n",
        "                    guidance_scale = gr.Slider(0.0, 4.0, value=2.0, step=0.1,\n",
        "                                               label=\"Guidance Scale (CFG)\")\n",
        "                with gr.Row():\n",
        "                    speed = gr.Slider(0.5, 1.5, value=1.0, step=0.05,\n",
        "                                      label=\"Скорость речи\")\n",
        "                    language = gr.Dropdown(\n",
        "                        choices=[\"Auto\", \"ru\", \"en\", \"zh\", \"es\", \"fr\",\n",
        "                                 \"de\", \"ja\", \"ko\"],\n",
        "                        value=\"Auto\",\n",
        "                        label=\"Язык (Auto = автоопределение)\",\n",
        "                        allow_custom_value=True,\n",
        "                    )\n",
        "\n",
        "        with gr.Column(scale=2):\n",
        "            ref_audio  = gr.Audio(\n",
        "                label=\"Референсное аудио (3–10 сек)\",\n",
        "                type=\"filepath\", visible=False,\n",
        "            )\n",
        "            ref_text   = gr.Textbox(\n",
        "                label=\"Текст референса (можно оставить пустым — распознается через Whisper)\",\n",
        "                visible=False,\n",
        "            )\n",
        "            spk_prompt = gr.Textbox(\n",
        "                label=\"Описание голоса (Instruct для Voice Design)\",\n",
        "                placeholder=\"Например: Male, Young Adult, Low Pitch, British Accent\",\n",
        "                visible=False,\n",
        "            )\n",
        "\n",
        "            btn    = gr.Button(\"🎙️ Генерировать\", variant=\"primary\", size=\"lg\")\n",
        "            status = gr.Textbox(label=\"Статус\", interactive=False)\n",
        "            output = gr.Audio(label=\"Результат\", type=\"filepath\")\n",
        "\n",
        "    mode.change(update_ui, inputs=mode,\n",
        "                outputs=[ref_audio, ref_text, spk_prompt])\n",
        "    btn.click(\n",
        "        generate_tts,\n",
        "        inputs=[text_input, ref_audio, ref_text, spk_prompt, mode,\n",
        "                num_step, guidance_scale, speed, language],\n",
        "        outputs=[output, status],\n",
        "    )\n",
        "\n",
        "demo.queue().launch(share=True, debug=False)"
      ],
